rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 1. Global Safety Net (default-deny)
    match /{document=**} {
      allow read, write: if false;
    }

    // 2. Rules for visitor messages
    match /messages/{messageId} {
      allow read, list: if true;
      allow create: if isValidId(messageId) && isValidMessage(request.resource.data);
      allow update: if false; // Messages are immutable after creation
      allow delete: if true;  // Allow users to clean up or delete messages for design freedom
    }

    // Reusable, hardened global helpers
    function isValidId(id) { 
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); 
    }

    function isValidMessage(data) {
      return data.keys().hasAll(['name', 'content', 'inkColor', 'stamp', 'timestamp', 'visitorId'])
        && (data.keys().size() == 6 || (data.keys().size() == 7 && data.keys().hasAll(['id'])))
        && data.name is string && data.name.size() > 0 && data.name.size() <= 100
        && data.content is string && data.content.size() > 0 && data.content.size() <= 1000
        && data.inkColor is string && data.inkColor.size() <= 32
        && data.stamp is string && data.stamp.size() <= 16
        && data.timestamp is string && data.timestamp.size() <= 32
        && data.visitorId is string && data.visitorId.size() <= 128;
    }
  }
}
